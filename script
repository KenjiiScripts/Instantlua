-- ====== DRAGGING ======
do
	local dragging = false
	local dragStart, startPos

	local function update(input)
		local delta = input.Position - dragStart
		main.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end

	main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = main.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	main.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			update(input)
		end
	end)
end

-- ====== LOGIC ======
local savedCFrame = nil

local function flashMessage(msg, good)
	notif.Text = msg
	notif.TextColor3 = good and Color3.fromRGB(120, 200, 120) or Color3.fromRGB(220, 140, 140)

	-- tiny fade in/out
	notif.TextTransparency = 1
	TweenService:Create(notif, TweenInfo.new(0.15), {TextTransparency = 0}):Play()

	task.delay(1.2, function()
		if notif and notif.Parent then
			TweenService:Create(notif, TweenInfo.new(0.25), {TextTransparency = 1}):Play()
		end
	end)
end

local function getHRP()
	local char = player.Character or player.CharacterAdded:Wait()
	return char:WaitForChild("HumanoidRootPart")
end

saveBtn.MouseButton1Click:Connect(function()
	local hrp = getHRP()
	savedCFrame = hrp.CFrame
	flashMessage("Location saved ✅", true)
end)

tpBtn.MouseButton1Click:Connect(function()
	if not savedCFrame then
		flashMessage("No location saved yet.", false)
		return
	end

	local hrp = getHRP()
	hrp.CFrame = savedCFrame
	flashMessage("Teleported ✅", true)
end)

blockBtn.MouseButton1Click:Connect(function()
	-- intentionally does nothing
	flashMessage("Block button does nothing (as requested).", true)
end)

-- Optional: toggle UI with RightShift
UIS.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.RightShift then
		main.Visible = not main.Visible
	end
end)
